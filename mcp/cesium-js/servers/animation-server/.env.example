# Animation Server Configuration

# Port for the animation server (default: 3004)
ANIMATION_SERVER_PORT=3004

# Maximum number of retry attempts for server connections (default: 10)
MAX_RETRIES=10

# Communication protocol: "websocket" or "sse" (default: websocket)
COMMUNICATION_PROTOCOL=websocket

# Strict port mode: if true, server will fail if port is unavailable (default: false)
STRICT_PORT=false

# MCP Transport: "stdio" or "streamable-http" (default: stdio)
MCP_TRANSPORT=stdio
MCP_TRANSPORT_ENDPOINT=
