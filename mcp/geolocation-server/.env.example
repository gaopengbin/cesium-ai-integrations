# ========================================
# Geolocation Server Configuration
# ========================================

# OpenStreetMap User-Agent (recommended)
# Should include app name/version and contact information
# Required by OSM usage policy: https://operations.osmfoundation.org/policies/nominatim/
OSM_USER_AGENT="MyApp/1.0 (contact@example.com)"

# Overpass Server URL (optional)
# Default: https://overpass-api.de/api/interpreter (public instance)
# For production, consider self-hosting: https://github.com/drolbr/Overpass-API
# OVERPASS_SERVER_URL=https://overpass-api.de/api/interpreter

# OSRM Server URL (optional)
# Default: https://router.project-osrm.org (public instance)
# For production, consider self-hosting: https://github.com/Project-OSRM/osrm-backend
# OSRM_SERVER_URL=https://router.project-osrm.org